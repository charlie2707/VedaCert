# Stellar Deployer Wallet Configuration
# Leave blank to auto-generate a new funded Keypair upon deploying
STELLAR_SECRET_KEY=

# Stellar Network Settings
STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Next.js Client Bindings
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract Addresses (Populate after running deployment script)
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=
NEXT_PUBLIC_VAULT_CONTRACT_ID=
